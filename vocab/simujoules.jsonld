{
  "@context": {
    "rdfs":        "http://www.w3.org/2000/01/rdf-schema#",
    "owl":         "http://www.w3.org/2002/07/owl#",
    "xsd":         "http://www.w3.org/2001/XMLSchema#",
    "schema":      "https://schema.org/",
    "qudt":        "http://qudt.org/schema/qudt/",
    "unit":        "http://qudt.org/vocab/unit/",
    "simu":        "https://pedalhidrografi.co/vocab/simujoules#",
    "label":       "rdfs:label",
    "comment":     "rdfs:comment",
    "domain":      { "@id": "rdfs:domain",     "@type": "@id" },
    "range":       { "@id": "rdfs:range",      "@type": "@id" },
    "subClassOf":  { "@id": "rdfs:subClassOf", "@type": "@id" },
    "hasUnit":     { "@id": "qudt:hasUnit",    "@type": "@id" }
  },

  "@graph": [

    { "@id": "simu:",
      "@type": "owl:Ontology",
      "label": "Simujoules vocabulary",
      "comment": "Terms describing an asymmetric-cost Dijkstra energy-field computation over a DEM, as produced by the Simulador bici-geo-energético web app. Each computation persists as a JSON-LD bundle with companion binary outputs (energy/passes rasters, network mask, route/path GeoJSON).",
      "schema:version": "2",
      "schema:license": "https://creativecommons.org/licenses/by/4.0/" },

    { "@id": "simu:EnergyFieldComputation",
      "@type": "owl:Class",
      "label": "Energy field computation",
      "comment": "A single Dijkstra run (or batch of runs) over a digital elevation model that records the cost-to-reach surface, optional pass-count surface, optional top-N routes, and the parameters/visualisation state that produced them." },

    { "@id": "simu:DigitalElevationModel",
      "@type": "owl:Class",
      "subClassOf": "geo:Geometry",
      "label": "Digital elevation model",
      "comment": "Rasterised heightfield consumed by the computation. Pixel-aligned, georeferenced via origin + cell size." },

    { "@id": "simu:Parameters",
      "@type": "owl:Class",
      "label": "Computation parameters",
      "comment": "User-controlled inputs to the cost function and route extraction." },

    { "@id": "simu:Visualisation",
      "@type": "owl:Class",
      "label": "Visualisation state",
      "comment": "Colormap, opacity, blend, and percentile ranges applied to the output rasters when rendered to the map." },

    { "@id": "simu:NetworkConstraint",
      "@type": "owl:Class",
      "label": "Network constraint",
      "comment": "Optional vector graph (typically a street/path network from a GeoPackage) rasterised into a binary mask. When present, the cost surface is computed only over network cells, with optional IDW interpolation across the gaps." },

    { "@id": "simu:Outputs",
      "@type": "owl:Class",
      "label": "Computation outputs",
      "comment": "Pointers to the binary and GeoJSON files that accompany the metadata in the bundle." },

    { "@id": "simu:BinaryRaster",
      "@type": "owl:Class",
      "label": "Binary raster",
      "comment": "A typed-array dump of an H×W grid, stored little-endian alongside the metadata." },


    { "@id": "simu:schemaVersion",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:EnergyFieldComputation",
      "range":  "xsd:integer",
      "label": "schema version",
      "comment": "Bundle schema revision. Increments only when a field's meaning changes; missing fields fall through to defaults on load." },

    { "@id": "simu:engine",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:EnergyFieldComputation",
      "range":  "xsd:string",
      "label": "compute engine",
      "comment": "Which engine actually ran the computation. One of 'js' or 'wasm'." },

    { "@id": "simu:enginePreference",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:EnergyFieldComputation",
      "range":  "xsd:string",
      "label": "user-selected engine",
      "comment": "User's preferred engine at save time. May differ from simu:engine when feature toggles forced a JS fallback." },

    { "@id": "simu:elapsedMs",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:EnergyFieldComputation",
      "range":  "xsd:double",
      "hasUnit": "unit:MilliSEC",
      "label": "elapsed time",
      "comment": "Wall-clock duration of the compute step, in milliseconds." },


    { "@id": "simu:H",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:DigitalElevationModel",
      "range":  "xsd:integer",
      "label": "rows",
      "comment": "Raster height in pixels." },

    { "@id": "simu:W",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:DigitalElevationModel",
      "range":  "xsd:integer",
      "label": "columns",
      "comment": "Raster width in pixels." },

    { "@id": "simu:originX",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:DigitalElevationModel",
      "range":  "xsd:double",
      "label": "origin X",
      "comment": "Easting (or longitude, when isGeographic) of the upper-left pixel corner, in DEM CRS units." },

    { "@id": "simu:originY",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:DigitalElevationModel",
      "range":  "xsd:double",
      "label": "origin Y",
      "comment": "Northing (or latitude, when isGeographic) of the upper-left pixel corner, in DEM CRS units." },

    { "@id": "simu:dx",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:DigitalElevationModel",
      "range":  "xsd:double",
      "label": "pixel size X",
      "comment": "Pixel size along the X axis, in DEM CRS units (degrees for geographic DEMs)." },

    { "@id": "simu:dy",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:DigitalElevationModel",
      "range":  "xsd:double",
      "label": "pixel size Y",
      "comment": "Pixel size along the Y axis, in DEM CRS units." },

    { "@id": "simu:dxM",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:DigitalElevationModel",
      "range":  "xsd:double",
      "hasUnit": "unit:M",
      "label": "pixel size X (metres)",
      "comment": "Pixel size along the X axis projected to metres via a flat-earth approximation when the DEM is geographic; equal to dx for projected DEMs." },

    { "@id": "simu:dyM",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:DigitalElevationModel",
      "range":  "xsd:double",
      "hasUnit": "unit:M",
      "label": "pixel size Y (metres)",
      "comment": "Pixel size along the Y axis in metres; equal to dy for projected DEMs." },

    { "@id": "simu:isGeographic",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:DigitalElevationModel",
      "range":  "xsd:boolean",
      "label": "is geographic",
      "comment": "True when the DEM CRS is lon/lat (EPSG:4326-style); false when projected metric (UTM etc.)." },


    { "@id": "simu:mode",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Parameters",
      "range":  "xsd:string",
      "label": "direction mode",
      "comment": "Direction of the Dijkstra. One of 'from' (source-out, the default), 'to' (destination-in), or 'round' (sum of from+to)." },

    { "@id": "simu:alpha",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Parameters",
      "range":  "xsd:double",
      "label": "distance weight α",
      "comment": "Coefficient on planimetric distance per cell traversal in the cost function. Higher α favours short paths regardless of slope." },

    { "@id": "simu:beta",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Parameters",
      "range":  "xsd:double",
      "label": "uphill weight β",
      "comment": "Coefficient on positive elevation gain in the cost function. Higher β makes climbs more expensive." },

    { "@id": "simu:eta",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Parameters",
      "range":  "xsd:double",
      "label": "downhill recovery η",
      "comment": "Fraction of the uphill cost recovered on descent. η=0 is fully asymmetric (free descents), η=1 is symmetric (descent costs as much as ascent did)." },

    { "@id": "simu:eMax",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Parameters",
      "range":  "xsd:double",
      "label": "energy budget",
      "comment": "Optional upper cutoff on the cost surface — cells whose cost-to-reach exceeds this value are not relaxed. 0 disables the cutoff." },

    { "@id": "simu:src",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Parameters",
      "label": "source pixel",
      "comment": "[row, column] integer pair of the source point. Null in density mode." },

    { "@id": "simu:dst",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Parameters",
      "label": "destination pixel",
      "comment": "[row, column] integer pair of the destination point. Null when not in to/round mode." },

    { "@id": "simu:wantPasses",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Parameters",
      "range":  "xsd:boolean",
      "label": "compute passes count",
      "comment": "Whether the worker recorded a pass-count raster (how many least-cost paths cross each cell)." },

    { "@id": "simu:wantTopN",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Parameters",
      "range":  "xsd:boolean",
      "label": "compute top-N routes",
      "comment": "Whether the worker extracted multiple distinct least-cost routes with mutual repulsion." },

    { "@id": "simu:nRoutes",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Parameters",
      "range":  "xsd:integer",
      "label": "number of routes",
      "comment": "How many distinct routes were requested when wantTopN is true." },

    { "@id": "simu:penalty",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Parameters",
      "range":  "xsd:double",
      "label": "repulsion penalty",
      "comment": "Multiplicative cost penalty applied to cells already used by a previously extracted route." },

    { "@id": "simu:repulsionMode",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Parameters",
      "range":  "xsd:string",
      "label": "repulsion mode",
      "comment": "How the route-repulsion mask is shaped. 'per-cell' inflates the cells crossed; 'distance' uses a chamfer transform so the penalty falls off with distance." },

    { "@id": "simu:wantDensity",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Parameters",
      "range":  "xsd:boolean",
      "label": "compute multi-reference density",
      "comment": "Whether the run is in density mode — a Dijkstra per reference point, with passes and energy averaged across refs." },

    { "@id": "simu:nRefs",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Parameters",
      "range":  "xsd:integer",
      "label": "reference cap",
      "comment": "Maximum number of reference points retained in the FIFO buffer." },

    { "@id": "simu:refSource",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Parameters",
      "range":  "xsd:string",
      "label": "reference source",
      "comment": "How references were placed. 'click' (manual map clicks) or 'random' (sampled from the DEM mask)." },

    { "@id": "simu:refPoints",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Parameters",
      "label": "reference points",
      "comment": "Ordered list of [row, column] pairs for density-mode references, in FIFO order." },


    { "@id": "simu:fieldColormap",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Visualisation",
      "range":  "xsd:string",
      "label": "energy colormap",
      "comment": "Identifier of the ColorCET colormap applied to the energy raster (e.g. 'CET_R2', 'cmo_phase')." },

    { "@id": "simu:routesColormap",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:Visualisation",
      "range":  "xsd:string",
      "label": "routes colormap",
      "comment": "Identifier of the colormap used to colour the top-N route lines by index." },

    { "@id": "simu:vmin",
      "@type": "owl:DatatypeProperty",
      "range":  "xsd:string",
      "label": "minimum range value",
      "comment": "Low end of the colormap stretch. May be a literal number or a percentile expression like 'p1'." },

    { "@id": "simu:vmax",
      "@type": "owl:DatatypeProperty",
      "range":  "xsd:string",
      "label": "maximum range value",
      "comment": "High end of the colormap stretch. May be a literal number or a percentile expression like 'p80'." },

    { "@id": "simu:opacity",
      "@type": "owl:DatatypeProperty",
      "range":  "xsd:double",
      "label": "layer opacity",
      "comment": "Layer opacity in the range [0, 1]." },

    { "@id": "simu:visible",
      "@type": "owl:DatatypeProperty",
      "range":  "xsd:boolean",
      "label": "layer visible",
      "comment": "Whether the layer is currently rendered on the map." },

    { "@id": "simu:blend",
      "@type": "owl:DatatypeProperty",
      "range":  "xsd:string",
      "label": "blend mode",
      "comment": "CSS mix-blend-mode applied to the passes overlay (e.g. 'plus-lighter', 'normal')." },

    { "@id": "simu:gamma",
      "@type": "owl:DatatypeProperty",
      "range":  "xsd:double",
      "label": "gamma",
      "comment": "Gamma applied before colormap lookup. γ=1 leaves intensity unchanged; γ=2 squares it; γ=0.5 takes the square root." },

    { "@id": "simu:meanWindow",
      "@type": "owl:DatatypeProperty",
      "range":  "xsd:integer",
      "label": "mean filter window",
      "comment": "Width of the box-mean filter applied to the passes raster before display. 1 disables filtering." },


    { "@id": "simu:enabled",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:NetworkConstraint",
      "range":  "xsd:boolean",
      "label": "network enabled",
      "comment": "Whether a network constraint was active for this run." },

    { "@id": "simu:srsId",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:NetworkConstraint",
      "range":  "xsd:integer",
      "label": "GeoPackage SRS id",
      "comment": "EPSG code of the source GeoPackage CRS (used to drive proj4 reprojection into the DEM CRS)." },

    { "@id": "simu:featureCount",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:NetworkConstraint",
      "range":  "xsd:integer",
      "label": "feature count",
      "comment": "Number of (Multi)LineString features rasterised from the GeoPackage." },

    { "@id": "simu:lineWidth",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:NetworkConstraint",
      "range":  "xsd:integer",
      "label": "rasterisation line width",
      "comment": "Half-width (in DEM cells) of the stamp dilated around each rasterised line segment." },

    { "@id": "simu:snapRadius",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:NetworkConstraint",
      "range":  "xsd:integer",
      "label": "snap radius",
      "comment": "Radius (in DEM cells) within which a clicked point is snapped to the nearest network cell." },

    { "@id": "simu:wantInterp",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:NetworkConstraint",
      "range":  "xsd:boolean",
      "label": "interpolate across non-network cells",
      "comment": "Whether GDAL-style IDW infill was applied to fill cost values into non-network cells after the Dijkstra." },

    { "@id": "simu:interpMaxDistance",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:NetworkConstraint",
      "range":  "xsd:integer",
      "label": "IDW max distance",
      "comment": "Maximum distance (in cells) the IDW search rays travel before giving up on a target cell." },

    { "@id": "simu:interpSmoothing",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:NetworkConstraint",
      "range":  "xsd:integer",
      "label": "smoothing passes",
      "comment": "Number of 3×3 box-mean passes applied after the IDW fill, preserving the original network cells." },


    { "@id": "simu:maxE",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:EnergyFieldComputation",
      "range":  "xsd:double",
      "label": "max energy",
      "comment": "Auto-detected maximum of the energy raster used for normalisation in the legend." },

    { "@id": "simu:maxPasses",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:EnergyFieldComputation",
      "range":  "xsd:double",
      "label": "max passes",
      "comment": "Auto-detected maximum of the passes raster." },

    { "@id": "simu:pathEnergy",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:EnergyFieldComputation",
      "range":  "xsd:double",
      "label": "path energy",
      "comment": "Total cost of the destination path, in the units determined by α and β." },

    { "@id": "simu:pathLengthM",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:EnergyFieldComputation",
      "range":  "xsd:double",
      "hasUnit": "unit:M",
      "label": "path length",
      "comment": "Planimetric length of the destination path, in metres." },


    { "@id": "simu:type",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:BinaryRaster",
      "range":  "xsd:string",
      "label": "typed-array kind",
      "comment": "Element type of the binary file: 'Float32Array', 'Float64Array', 'Uint8Array', or 'GeoJSON' for line layers." },

    { "@id": "simu:shape",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:BinaryRaster",
      "label": "raster shape",
      "comment": "[H, W] pixel dimensions, matching the DEM's." },

    { "@id": "simu:file",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:BinaryRaster",
      "range":  "xsd:string",
      "label": "filename",
      "comment": "Relative filename of the companion file inside the bundle archive." },

    { "@id": "simu:byteOrder",
      "@type": "owl:DatatypeProperty",
      "domain": "simu:BinaryRaster",
      "range":  "xsd:string",
      "label": "byte order",
      "comment": "Endianness of the binary payload. Always 'little-endian' for typed arrays; 'n/a' for the network mask (single-byte cells) and GeoJSON files." }

  ]
}
